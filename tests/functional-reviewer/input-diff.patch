@@ -0,0 +1,24 @@
+'use client';
+import { useState } from 'react';
+
+export function DarkModeToggle() {
+  const [isDark, setIsDark] = useState(false);
+
+  const toggle = () => {
+    const next = !isDark;
+    setIsDark(next);
+    document.documentElement.classList.toggle('dark', next);
+  };
+
+  return (
+    <button
+      data-testid="dark-mode-toggle"
+      onClick={toggle}
+      aria-label="Toggle dark mode"
+    >
+      {isDark ? 'Light' : 'Dark'}
+    </button>
+  );
+}
